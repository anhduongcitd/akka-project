# Online Payment Service - Environment Variables

# Stripe Payment Gateway
# Get your API key from: https://dashboard.stripe.com/apikeys
# Use test keys for development (starts with sk_test_)
STRIPE_API_KEY=sk_test_your_stripe_test_api_key_here

# AWS SES (Simple Email Service) for Email Notifications
# Create IAM user with SES permissions: https://console.aws.amazon.com/iam/
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1

# Email sender (must be verified in AWS SES)
# Verify email address: https://console.aws.amazon.com/ses/home#verified-senders-email:
SES_FROM_EMAIL=noreply@example.com

# Exchange Rate API (for multi-currency support)
# Free API options: https://exchangerate-api.com/ or https://openexchangerates.org/
EXCHANGE_RATE_API_URL=https://api.exchangerate-api.com/v4/latest/USD
EXCHANGE_RATE_API_KEY=your_exchange_rate_api_key_here

# Notes:
# - Copy this file to .env and fill in your actual values
# - Never commit .env file to version control
# - For production, use proper secret management (AWS Secrets Manager, Vault, etc.)
